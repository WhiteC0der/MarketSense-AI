# =============================================================
# .gitignore  —  MarketSense AI (covers backend + frontend)
# =============================================================

# ── Dependencies ──────────────────────────────────────────────
**/node_modules/

# ── Environment variables (NEVER commit real secrets) ─────────
**/.env
**/.env.local
**/.env.*.local
!**/.env.example

# ── Build outputs ─────────────────────────────────────────────
**/dist/
**/dist-ssr/
**/build/

# ── Logs ──────────────────────────────────────────────────────
**/logs/
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*
**/lerna-debug.log*

# ── Test / Coverage ───────────────────────────────────────────
**/coverage/
**/.nyc_output/
**/playwright-report/
**/test-results/

# ── Runtime artefacts (Node.js) ───────────────────────────────
**/pids/
**/*.pid
**/*.pid.lock
**/*.seed
**/*.pem
**/uploads/

# ── Cache ─────────────────────────────────────────────────────
**/.npm/
**/.yarn/
**/.eslintcache
**/.parcel-cache/

# ── TypeScript ────────────────────────────────────────────────
**/*.tsbuildinfo

# ── Vite ──────────────────────────────────────────────────────
**/*.local

# ── OS generated files ────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db

# ── IDE ───────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
*~

